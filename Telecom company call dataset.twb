          <format attr='background-color' value='#ffffffbc' />
          <format attr='border-width' value='3' />
          <format attr='border-color' value='#aa007f' />
        </style-rule>
      </style>
      <size maxheight='764' maxwidth='1616' minheight='764' minwidth='1616' sizing-mode='fixed' />
      <zones>
        <zone h='100000' id='2' type-v2='layout-basic' w='100000' x='0' y='0'>
          <zone h='97906' id='7' param='vert' removable='false' type-v2='layout-flow' w='99010' x='495' y='1047'>
            <zone h='6283' id='8' type-v2='title' w='99010' x='495' y='1047'>
              <zone-style>
                <format attr='border-color' value='#000000' />
                <format attr='border-style' value='none' />
                <format attr='border-width' value='0' />
                <format attr='margin' value='4' />
              </zone-style>
            </zone>
            <zone h='91623' id='1' param='vert' removable='false' type-v2='layout-flow' w='99010' x='495' y='7330'>
              <zone h='13220' id='4' is-fixed='true' paired-zone-id='5' removable='false' type-v2='flipboard-nav' w='99010' x='495' y='7330' />
              <zone h='78403' id='5' paired-zone-id='4' removable='false' type-v2='flipboard' w='99010' x='495' y='20550'>
                <flipboard active-id='14' nav-type='caption' show-nav-arrows='true'>
                  <story-points>
                    <story-point caption='Dashboard' captured-sheet='TELECOM CUSTOMER BEHAVIOR &amp; SUPPORT PERFORMANCE OVERVIEW' id='15' />
                    <story-point caption='Churn by Payment Method' captured-sheet='Churn by Payment Method' id='8'>
                      <capturedDeltas>
                        <worksheet name='Churn by Payment Method'>
                          <selection-collection />
                        </worksheet>
                      </capturedDeltas>
                    </story-point>
                    <story-point caption='Churn by Contract Type' captured-sheet='Churn by Contract Type' id='7' />
                    <story-point caption='Customer Churn Distribution' captured-sheet='Churn Distribution' id='9' />
                    <story-point caption='Support Calls by Topic' captured-sheet='Call by Topic' id='10' />
                    <story-point caption='Agent Performance by Topic' captured-sheet='Agent vs Topic' id='12' />
                    <story-point caption='Call Volume Trend Analysis' captured-sheet='Calls Trend by Date' id='11' />
                    <story-point caption='Key Findings &amp; Recommendations' captured-sheet='' id='14' />
                    <story-point caption='Churn Rate' captured-sheet='Churn Rate ' id='17' />
                    <story-point caption='Average monthly charges' captured-sheet='Average Monthly Charges' id='18' />
                    <story-point caption='Average Tenure months' captured-sheet='Average Tenure' id='19' />
                  </story-points>
                </flipboard>
              </zone>
            </zone>
          </zone>
          <zone-style>
            <format attr='border-color' value='#000000' />
            <format attr='border-style' value='none' />
            <format attr='border-width' value='0' />
            <format attr='margin' value='8' />
          </zone-style>
        </zone>
        <zone flipboard-zone-id='5' h='71577' id='9' story-point-id='14' type-v2='text' w='94789' x='2243' y='16701'>
          <formatted-text>
            <run fontalignment='0' fontcolor='#ffffff' fontname='Arial Narrow'>Key Findings</run>
            <run fontalignment='0'>Æ&#10;&#10;</run>
            <run fontalignment='0' fontcolor='#ffffff' fontname='Arial Narrow' fontsize='11'>✅ 26.54% of customers have churned, indicating a significant customer retention challenge.</run>
            <run fontalignment='0'>Æ&#10;&#10;</run>
            <run fontalignment='0' fontcolor='#ffffff' fontname='Arial Narrow' fontsize='11'>✅ Month-to-Month contract customers show the highest churn rate, while customers on long-term contracts are more likely to stay.</run>
            <run fontalignment='0'>Æ&#10;&#10;</run>
            <run fontalignment='0' fontcolor='#ffffff' fontname='Arial Narrow' fontsize='11'>✅ Electronic Check users have the highest churn, suggesting potential dissatisfaction or higher-risk customer segments.</run>
            <run fontalignment='0'>Æ&#10;&#10;</run>
            <run fontalignment='0' fontcolor='#ffffff' fontname='Arial Narrow' fontsize='11'>✅ Technical Support and Streaming-related issues generate the highest call volumes, highlighting common customer pain points.</run>
            <run fontalignment='0'>Æ&#10;&#10;</run>
            <run fontalignment='0' fontcolor='#ffffff' fontname='Arial Narrow' fontsize='11'>✅ Support workload is unevenly distributed across topics and agents, creating opportunities for training and process improvements.</run>
            <run fontalignment='0'>Æ&#10;&#10;</run>
            <run fontalignment='0' fontcolor='#ffffff' fontname='Arial Narrow' fontsize='11'>⸻</run>
            <run fontalignment='0'>Æ&#10;&#10;</run>
            <run fontalignment='0' fontcolor='#ffffff' fontname='Arial Narrow'>Recommendations</run>
            <run fontalignment='0'>Æ&#10;&#10;</run>
            <run fontalignment='0' fontcolor='#ffffff' fontname='Arial Narrow' fontsize='11'>📌 Promote long-term contracts through discounts and loyalty benefits to reduce churn.</run>
            <run fontalignment='0'>Æ&#10;&#10;</run>
            <run fontalignment='0' fontcolor='#ffffff' fontname='Arial Narrow' fontsize='11'>📌 Target high-risk customers, especially Month-to-Month and Electronic Check users, with retention campaigns.</run>
            <run fontalignment='0'>Æ&#10;&#10;</run>
            <run fontalignment='0' fontcolor='#ffffff' fontname='Arial Narrow' fontsize='11'>📌 Improve Technical Support and Streaming services to reduce customer complaints and support calls.</run>
            <run fontalignment='0'>Æ&#10;&#10;</run>
            <run fontalignment='0' fontcolor='#ffffff' fontname='Arial Narrow' fontsize='11'>📌 Provide additional training for support agents in high-volume issue categories.</run>
            <run fontalignment='0'>Æ&#10;&#10;</run>
            <run fontalignment='0' fontcolor='#ffffff' fontname='Arial Narrow' fontsize='11'>📌 Monitor churn trends regularly and implement proactive customer engagement strategies.</run>
          </formatted-text>
        </zone>
      </zones>
      <simple-id uuid='{0B10F20C-4F30-46D6-B755-1DEF69D94DB8}' />
    </dashboard>
  </dashboards>
